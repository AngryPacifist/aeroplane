---
import "../styles/global.css";
import AnalyticsClickTracking from "../components/analytics-click-tracking.astro";
import PosthogTracking from "../components/posthog-tracking.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Aeroplane - Self-hosted deployments",
  description = "Aeroplane is a self-hosted deployment control plane for apps, databases, domains, logs, and backups.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <PosthogTracking />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <AnalyticsClickTracking />
  </body>
</html>
